<%
  issue = local_assigns[:issue] || @issue

  # Only show on existing issues (not the New Issue form)
  return if issue.nil? || issue.new_record?
  return unless issue.attributes_editable?

  assignable_user_ids = issue.assignable_users.map(&:id)
  author    = issue.author if issue.author && assignable_user_ids.include?(issue.author_id)
  last_user = issue.journals.reorder(id: :desc).detect { |j| j.user.present? }&.user
  last_user = nil unless last_user && assignable_user_ids.include?(last_user.id)
  prev_detail = JournalDetail.joins(:journal)
    .where(journals: { journalized_type: 'Issue', journalized_id: issue.id },
           property: 'attr', prop_key: 'assigned_to_id')
    .reorder('journals.id DESC').first
  prev_user = User.find_by(id: prev_detail&.old_value.presence)
  prev_user = nil unless prev_user && assignable_user_ids.include?(prev_user.id)
  return unless author || last_user || prev_user
%>

<% content_for :header_tags do %>
<style id="rqa-styles">
.rqa-edit-bar,.quick-assign-actions{display:flex;flex-wrap:wrap;align-items:center;gap:6px;margin:8px 0 4px;padding:6px 0;border-top:1px solid #e0e0e0}
.rqa-label{font-size:.8rem;font-weight:600;color:#555;white-space:nowrap;margin-right:4px}
.rqa-btn{display:inline-flex;align-items:center;gap:4px;padding:4px 10px;font-size:.78rem;font-family:inherit;color:#333;background:#f4f4f4;border:1px solid #ccc;border-radius:3px;cursor:pointer;white-space:nowrap;line-height:1.4;text-decoration:none}
.rqa-btn:hover{background:#e8e8e8;border-color:#aaa;box-shadow:0 1px 3px rgba(0,0,0,.12)}
.rqa-btn--active{background:#d4edda;border-color:#6abf77;color:#276b34;font-weight:600}
.rqa-icon{width:13px;height:13px;fill:currentColor;flex-shrink:0}
.rqa-name{color:#777;font-weight:400}
.rqa-btn--active .rqa-name{color:#2d7a3a}
.rqa-feedback{font-size:.78rem;color:#276b34;font-weight:600;opacity:0;transition:opacity .3s;margin-left:4px}
.rqa-feedback--visible{opacity:1}
@media(max-width:540px){.rqa-edit-bar,.quick-assign-actions{flex-direction:column;align-items:flex-start}.rqa-btn{width:100%;justify-content:center}}
</style>
<% end %>

<div class="rqa-edit-bar">
  <span class="rqa-label"><%= l(:label_quick_assign) %>:</span>

  <% if author %>
    <button type="button"
            class="rqa-btn rqa-edit-btn"
            data-rqa-user-id="<%= author.id %>"
            data-rqa-user-name="<%= h(author.name) %>"
            data-rqa-unavailable="<%= h(l(:notice_quick_assign_unavailable)) %>">
      <svg class="rqa-icon" viewBox="0 0 16 16" aria-hidden="true"><path d="M8 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6Zm5 5a5 5 0 0 0-10 0h10Z"/></svg>
      <%= l(:button_quick_assign_author) %>
      <span class="rqa-name">(<%= h(author.name) %>)</span>
    </button>
  <% end %>

  <% if last_user %>
    <button type="button"
            class="rqa-btn rqa-edit-btn"
            data-rqa-user-id="<%= last_user.id %>"
            data-rqa-user-name="<%= h(last_user.name) %>"
            data-rqa-unavailable="<%= h(l(:notice_quick_assign_unavailable)) %>">
      <svg class="rqa-icon" viewBox="0 0 16 16" aria-hidden="true"><path d="M8 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6Zm5 5a5 5 0 0 0-10 0h10Z"/></svg>
      <%= l(:button_quick_assign_last) %>
      <span class="rqa-name">(<%= h(last_user.name) %>)</span>
    </button>
  <% end %>

  <% if prev_user %>
    <button type="button"
            class="rqa-btn rqa-edit-btn"
            data-rqa-user-id="<%= prev_user.id %>"
            data-rqa-user-name="<%= h(prev_user.name) %>"
            data-rqa-unavailable="<%= h(l(:notice_quick_assign_unavailable)) %>">
      <svg class="rqa-icon" viewBox="0 0 16 16" aria-hidden="true"><path d="M8 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6Zm5 5a5 5 0 0 0-10 0h10Z"/></svg>
      <%= l(:button_quick_assign_previous) %>
      <span class="rqa-name">(<%= h(prev_user.name) %>)</span>
    </button>
  <% end %>

  <span class="rqa-feedback" aria-live="polite"></span>
</div>
